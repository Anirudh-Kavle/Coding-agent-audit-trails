{
  "description": "Flight Recorder local audit capture for Claude",
  "hooks": {
    "PreToolUse": [{"matcher": ".*", "hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}],
    "PostToolUse": [{"matcher": ".*", "hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}],
    "PermissionRequest": [{"matcher": ".*", "hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}],
    "PreCompact": [{"hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}],
    "PostCompact": [{"hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}],
    "SessionStart": [{"hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}],
    "SubagentStart": [{"hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}],
    "SubagentStop": [{"hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}],
    "UserPromptSubmit": [{"hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}],
    "Stop": [{"hooks": [{"type": "command", "command": "fr-hook --provider claude", "timeout": 5}]}]
  }
}
